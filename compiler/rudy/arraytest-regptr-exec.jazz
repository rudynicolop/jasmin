/* Experiment to see what occurs when one aliases arrays.

   NOTE: Examening what occurs for stack in this example,
   not register arrays (reg ptr), since these need to be (explicitly?)
   allocated somewhere.

*/

/* Needs to return b, otherwise b will be flagged as immutable...? */
export
fn assign(reg ptr u32[2] a, reg ptr u32[2] b) -> reg ptr u32[2] {

   /* Assign b to a. */
   b = a;

   /* compiler error: stack allocation, cannot write to b since it's now constant a? */
   b[0] = 2;

   return b;
}

export
fn main () -> reg u32 {
   /* Declare arrays. */
   stack u32[2] a;
   stack u32[2] b;

   /* Assign initial values */
   a[0] = 1;
   a[1] = 1;
   b[0] = 3;
   b[1] = 3;

   /* Do I need to do this? */
   reg ptr u32[2] asub = a;
   reg ptr u32[2] bsub = b;

   reg ptr u32[2] bnew = assign(asub, bsub);

   /* Was a[0] modified? */
   reg u32 x = a[0];

   /* Seems to return 1, meaning a[0] was not modified...? */
   return x;
}

exec main()
