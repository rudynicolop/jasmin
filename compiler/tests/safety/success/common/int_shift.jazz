/* What does it mean for main to accept some arbitrary `reg u32` argument?
   Where is the value coming from?

   Note that the program result is equivalent to computing `r = x * 7`,
   and `x` is often (arbitrarily?) `2`. */
export
fn main(reg u32 x) -> reg u32 {
  inline int i;
  reg u32 r;
  r = x;
  /* Upper bound of the loop is `(1 << 3) - (5 >> 1) = 6`.
     Also, it seems to be replacing the whole loop computation
     with a closed form arithmetic expression. */
  for i = 0 to (1 << 3) - (5 >> 1) {
    r += x;
  }
  return r;
}
